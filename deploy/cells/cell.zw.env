# =============================================================================
# Cell: ZW (Zimbabwe) — current home market, single active deployment today.
# =============================================================================
# Committed defaults only. Secrets live in deploy/cells/cell.zw.local.env on
# the host (gitignored); the deploy script layers it on top of this file via
# `docker compose --env-file cell.zw.env --env-file cell.zw.local.env up -d`.
# See deploy/README.md for the full provisioning workflow.
#
# To stand up a second cell (e.g. Kenya):
#   cp deploy/cells/cell.example.env deploy/cells/cell.ke.env
#   # edit ~6 values, then on the host create cell.ke.local.env with secrets
#   deploy/cell.sh ke up
# =============================================================================

# -- Cell identity -----------------------------------------------------------
INNBUCKS_COUNTRY=ZW

# -- Settlement currency (ISO 4217) ------------------------------------------
INNBUCKS_CURRENCY=USD

# -- Edge routing: cell registry (step 7) ------------------------------------
# {ISO -> public api-gateway base URL}, consumed by user-service for
# /cells/lookup and 409 wrong_cell redirects. Today ZW is the only live cell,
# so it maps to itself (lets the app confirm a ZW customer's home base URL).
# Add an entry — and redeploy this + every other cell with the SAME map — when
# a new market (e.g. KE) goes live. dtx.innbucks.co.zw is the ZW gateway origin
# (where /brand/** is already served); adjust if the public host differs.
INNBUCKS_CELLS_REGISTRY={"ZW":"https://dtx.innbucks.co.zw"}

# -- Image registry ----------------------------------------------------------
# Override IMAGE_TAG per-deploy on the command line (e.g. sha-<commit>);
# `latest` is the default for convenience but not what a prod release pins.
GHCR_OWNER=mpofuslim
IMAGE_TAG=latest

# -- Spring runtime profile --------------------------------------------------
SPRING_PROFILES_ACTIVE=prod,json

# -- CORS --------------------------------------------------------------------
# Zimbabwe FE origins. Today the super-app FE serves all markets from one
# domain (Vercel-hosted); when per-country FE domains exist, this list
# becomes country-specific.
CORS_ALLOWED_ORIGINS=https://innvents.vercel.app,https://innbucks-ticketing.vercel.app

# -- Postgres ----------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=REPLACE_ME_in_cell.zw.local.env

# -- Redis -------------------------------------------------------------------
REDIS_PASSWORD=REPLACE_ME_in_cell.zw.local.env

# -- Eureka registry auth ----------------------------------------------------
EUREKA_USERNAME=eureka
EUREKA_PASSWORD=REPLACE_ME_in_cell.zw.local.env

# -- JWT signing -------------------------------------------------------------
JWT_SECRET=REPLACE_ME_in_cell.zw.local.env

# -- Inter-service shared secrets --------------------------------------------
ORADIAN_INTERNAL_TOKEN=REPLACE_ME_in_cell.zw.local.env
INTERNAL_API_TOKEN=REPLACE_ME_in_cell.zw.local.env

# -- Loyalty signing secrets -------------------------------------------------
LOYALTY_VOUCHER_SECRET=REPLACE_ME_in_cell.zw.local.env
LOYALTY_QR_SECRET=REPLACE_ME_in_cell.zw.local.env

# -- First-run admin bootstrap (one-time; clear after first deploy) ----------
BOOTSTRAP_ADMIN_PASSWORD=

# -- WhatsApp gateway --------------------------------------------------------
# Dev ngrok URL by default (rotates frequently); set the real ZW provider URL
# in cell.zw.local.env when one is in place.
WHATSAPP_GATEWAY_URL=https://maximum-implicitly-treefrog.ngrok-free.app
WHATSAPP_API_KEY=REPLACE_ME_in_cell.zw.local.env

# -- InnBucks core gateway adapter -------------------------------------------
# Current host-resident jar on the ZW EC2 — adjust per cell's network layout.
INNBUCKS_GATEWAY_URL=http://10.0.155.69:8088

# -- Gateway rate limiting ---------------------------------------------------
RATE_LIMIT_REPLENISH_PER_SECOND=50
RATE_LIMIT_BURST_CAPACITY=100

# -- Tracing -----------------------------------------------------------------
TRACING_ENABLED=false
OTLP_ENDPOINT=http://localhost:4318/v1/traces
