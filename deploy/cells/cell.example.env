# =============================================================================
# CELL TEMPLATE — copy this file to deploy/cells/cell.<country>.env
# =============================================================================
#
# Step 5 of the multi-cell deployment roadmap. Each InnBucks country runs as
# its own independent stack ("cell"). Adding cell #N+1 = copying this file +
# changing ~6 values + running `deploy/cell.sh <country> up`. No service code
# changes required, ever.
#
# Two-file layered config per cell:
#   deploy/cells/cell.<country>.env       — COMMITTED (this file)
#       The cell's identity + non-secret defaults. Reviewed in PRs.
#   deploy/cells/cell.<country>.local.env  — GITIGNORED
#       Real secrets only. Created by the operator on the host. Overrides
#       any value in the committed file. See deploy/README.md for the
#       full provisioning workflow.
#
# To add a new cell:
#   1. Copy this file to `deploy/cells/cell.<iso>.env`
#      (e.g. deploy/cells/cell.ke.env for Kenya)
#   2. Set INNBUCKS_COUNTRY to the cell's ISO 3166-1 alpha-2 code
#      (one of: ZW KE ZM MW ZA BW MZ LS SZ NG)
#   3. Set CORS_ALLOWED_ORIGINS to the country's FE domain(s)
#   4. Set GHCR_OWNER / IMAGE_TAG for the image registry coordinates
#   5. Create `cell.<iso>.local.env` on the host with the secret values
#      (REPLACE_ME entries below)
#   6. `deploy/cell.sh <iso> up`
# =============================================================================

# -----------------------------------------------------------------------------
# Cell identity
# -----------------------------------------------------------------------------
# ISO 3166-1 alpha-2 country code. Every JVM service in this cell validates
# the value at boot and refuses to start with anything outside the InnBucks
# market allowlist: ZW KE ZM MW ZA BW MZ LS SZ NG. Sets the deployment-side
# `country` MDC tag on every log line. See CountryMdcConfig in any service.
INNBUCKS_COUNTRY=ZW

# This cell's settlement currency (ISO 4217). Drives payment-service ticket
# payments and loyalty-service merchant/QR defaults. Must match the market:
#   ZW -> USD,  KE -> KES,  ZM -> ZMW,  etc.
INNBUCKS_CURRENCY=USD

# Step 7 — edge routing. JSON map of {ISO 3166-1 alpha-2 -> that cell's public
# api-gateway base URL}. Consumed ONLY by user-service: the mobile app calls
# GET /cells/lookup?msisdn=... to discover its home cell, and a request that
# lands on the wrong cell is rejected 409 wrong_cell carrying the home cell's
# URL so the client can switch and retry.
#   - Include an entry for EVERY live cell, INCLUDING this one (so /cells/lookup
#     returns a local customer their own base URL).
#   - Keep this map identical across all cells' env files — every cell must be
#     able to redirect to every other. Updating it is the one step when a new
#     market goes live.
#   - Empty ({}) is legal: wrong_cell still returns the home COUNTRY, just no URL.
# Example with two live markets:
INNBUCKS_CELLS_REGISTRY={"ZW":"https://dtx.innbucks.co.zw","KE":"https://dtx.innbucks.co.ke"}


# -----------------------------------------------------------------------------
# Image registry
# -----------------------------------------------------------------------------
# Container image owner + tag. Compose templates pull from
#   ghcr.io/${GHCR_OWNER}/<service>:${IMAGE_TAG}
# IMAGE_TAG is normally a `sha-<commit>` set by the Release workflow.
# `latest` / `dev` are local-convenience tags and MUST NOT be used in prod.
GHCR_OWNER=mpofuslim
IMAGE_TAG=latest


# -----------------------------------------------------------------------------
# Spring runtime profile
# -----------------------------------------------------------------------------
# `prod` activates ProductionSecretsGuard (refuses to boot on change-me-*
# placeholders); `json` switches logback to Logstash-encoded JSON so
# Loki/ELK/CloudWatch can ingest structured logs. Drop `json` only for
# local human-readable tailing.
SPRING_PROFILES_ACTIVE=prod,json


# -----------------------------------------------------------------------------
# CORS — per-cell frontend origins
# -----------------------------------------------------------------------------
# Comma-separated list of origins allowed to call this cell's api-gateway.
# Each cell typically serves a country-scoped FE domain, e.g.
#   ZW: https://app-zw.innbucks.com
#   KE: https://app-ke.innbucks.com
# Wildcards intentionally NOT supported (allowCredentials=true forbids it).
CORS_ALLOWED_ORIGINS=https://app.example.com


# -----------------------------------------------------------------------------
# Postgres credentials
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=REPLACE_ME_in_cell.local.env


# -----------------------------------------------------------------------------
# Redis password
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
REDIS_PASSWORD=REPLACE_ME_in_cell.local.env


# -----------------------------------------------------------------------------
# Eureka registry auth
# -----------------------------------------------------------------------------
# HTTP Basic. Password MUST be URL-safe (no @ : /) — services embed it in
# their defaultZone URL. Generate with: openssl rand -hex 24
EUREKA_USERNAME=eureka
EUREKA_PASSWORD=REPLACE_ME_in_cell.local.env


# -----------------------------------------------------------------------------
# JWT signing
# -----------------------------------------------------------------------------
# HS256 shared across every service IN THIS CELL. Different cells SHOULD have
# different JWT_SECRETs today — a token minted by cell ZW will not validate
# in cell KE. (Step 6 of the multi-cell roadmap replaces this with RS256 +
# JWKS so cells trust each other's tokens via published public keys instead
# of a shared secret.) Generate with: openssl rand -base64 48
JWT_SECRET=REPLACE_ME_in_cell.local.env


# -----------------------------------------------------------------------------
# Inter-service shared secrets
# -----------------------------------------------------------------------------
# ORADIAN_INTERNAL_TOKEN: X-Internal-Token presented to the Oradian
# middleware (sibling stack). MUST match the middleware's INTERNAL_API_TOKEN.
ORADIAN_INTERNAL_TOKEN=REPLACE_ME_in_cell.local.env
# INTERNAL_API_TOKEN: shared secret between this cell's own services
# (booking↔event, user↔loyalty). Separate concern from ORADIAN_*.
INTERNAL_API_TOKEN=REPLACE_ME_in_cell.local.env


# -----------------------------------------------------------------------------
# Loyalty signing secrets
# -----------------------------------------------------------------------------
# Generate each with: openssl rand -base64 32
LOYALTY_VOUCHER_SECRET=REPLACE_ME_in_cell.local.env
LOYALTY_QR_SECRET=REPLACE_ME_in_cell.local.env


# -----------------------------------------------------------------------------
# First-run admin bootstrap (optional)
# -----------------------------------------------------------------------------
# Leave UNSET to skip seeding — under the prod profile the service refuses to
# create a known-credential admin. Set a strong unique value to bootstrap the
# first SUPER_ADMIN for this cell; they're forced to change it on first login.
BOOTSTRAP_ADMIN_PASSWORD=


# -----------------------------------------------------------------------------
# WhatsApp gateway (per-cell — Africa's Talking / wasenda / etc.)
# -----------------------------------------------------------------------------
# Each country typically has its own MNO-licensed WhatsApp gateway. Override
# the URL per cell. The api-key is a required secret.
WHATSAPP_GATEWAY_URL=https://gateway.example.com
WHATSAPP_API_KEY=REPLACE_ME_in_cell.local.env


# -----------------------------------------------------------------------------
# InnBucks core gateway adapter (RETIRED)
# -----------------------------------------------------------------------------
# The `innbucks-core-gateway` connectivity spike (EOL Spring Boot 3.2.4) was
# retired — the services' SMS path already moved to the authenticated notify
# API, so nothing in the cell serves :8088 today. This var is kept only so the
# existing (inert) client config resolves; leave the placeholder. If the
# veengu/messenger integration is rebuilt, do it as a Boot-4 reactor module and
# repoint this at the new service.
INNBUCKS_GATEWAY_URL=http://10.0.0.1:8088


# -----------------------------------------------------------------------------
# Gateway rate limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_REPLENISH_PER_SECOND=50
RATE_LIMIT_BURST_CAPACITY=100


# -----------------------------------------------------------------------------
# Swagger UI access (api-gateway)
# -----------------------------------------------------------------------------
# HTTP Basic login in front of the aggregated Swagger UI at the gateway, the
# only publicly reachable copy of the docs (every backend service binds its own
# /v3/api-docs + /swagger-ui to 127.0.0.1). With SWAGGER_PASSWORD blank:
#   - prod profile (what cells run): Swagger is DISABLED, returns 404 (fail closed).
#   - non-prod: Swagger is left OPEN and a loud startup warning is logged.
# Set it in cell.<iso>.local.env to expose the docs behind a login in any profile.
# NOT a boot-required secret. Username defaults to "admin". Generate a password
# with: openssl rand -base64 18
SWAGGER_USER=admin
SWAGGER_PASSWORD=


# -----------------------------------------------------------------------------
# Tracing (optional)
# -----------------------------------------------------------------------------
TRACING_ENABLED=false
OTLP_ENDPOINT=http://localhost:4318/v1/traces


# -----------------------------------------------------------------------------
# Event-organizer invoicing (booking-service)
# -----------------------------------------------------------------------------
# Platform commission billed to each event organizer on their CONFIRMED ticket
# revenue, invoiced per billing cycle. All optional — booking-service ships safe
# defaults; override per cell as needed. Rates are PERCENTAGES (10.0 = 10%).
#   INVOICE_VAT_RATE is country-specific (ZW VAT = 15.0). Keep it accurate per
#   market. Changing a rate affects only FUTURE invoices (issued invoices snapshot
#   the rate they were billed at).
INVOICE_DEFAULT_COMMISSION_RATE=10.0
INVOICE_VAT_RATE=15.0
# WEEKLY or MONTHLY. Per-organizer overrides are set via the admin
# PUT /invoices/billing-config/{organizerUuid} endpoint.
INVOICE_DEFAULT_BILLING_CYCLE=MONTHLY
# Days from issue to due date.
INVOICE_DUE_DAYS=14
# Master switch for the periodic generation + overdue-sweep jobs.
INVOICE_SCHEDULER_ENABLED=true


# -----------------------------------------------------------------------------
# InnBucks API credentials (payments + notifications)
# -----------------------------------------------------------------------------
# The MERCHANT-type client creds for the InnBucks API Gateway. Already required
# by payment-service for the 2D-code rail; now ALSO consumed by booking-service
# and user-service to send email via POST /api/notification/email (system-user
# onboarding/credential emails + booking-confirm emails). Put the real values in
# cell.<iso>.local.env (gitignored). If left blank, email silently no-ops and the
# services fall back to SMS/WhatsApp — so set them to actually deliver email.
BANK_API_URL=https://staging.innbucks.co.zw
BANK_API_KEY=REPLACE_ME_in_cell.local.env
BANK_API_USERNAME=REPLACE_ME_in_cell.local.env
BANK_API_PASSWORD=REPLACE_ME_in_cell.local.env

# Read timeout for the InnBucks notify-api login + email send (user-service).
# The notify-api login (POST /auth/third-party) measures ~19s on a healthy
# response — slow but functional. Default is 30000ms (see user-service
# application.yaml); raise here when an upstream needs more headroom.
# Safe to be generous: credential delivery is fully async (no FE blocks).
# BANK_API_READ_TIMEOUT_MS=30000

# -----------------------------------------------------------------------------
# 2FA / TOTP encryption key (user-service)
# -----------------------------------------------------------------------------
# AES-GCM-256 key that protects users.mfa_secret at rest. Base64'd 32-byte
# value. Generate with: openssl rand -base64 32
# Must be STABLE: rotating it makes every existing user's TOTP secret
# undecodable, forcing every 2FA-enrolled user to reset via the admin
# /admin/users/{id}/mfa/reset path. Treat like NATIONAL_ID_HMAC_SECRET.
MFA_ENCRYPTION_KEY=REPLACE_ME_in_cell.local.env

# Label authenticator apps (Google Authenticator / Authy / etc.) show next to
# the account when the user scans the QR. Purely cosmetic — no security effect.
# Suggested values: "InnBucks" (customer apps), "SwiftInn" (system-user apps).
MFA_ISSUER=InnBucks
