# Copy this file to `.env` and fill it in. `.env` is gitignored so your real
# secrets never end up in version control. docker-compose automatically reads
# `.env` from the project root.

# JWT signing key. HS256 requires at least 256 bits (32 chars); 48+ bytes of
# base64 (≥64 chars) is a comfortable margin. Generate a fresh one with:
#     openssl rand -base64 48
#
# Every service (user/event/seat/booking) must share the same value so tokens
# minted by user-service validate everywhere else. Rotate it by updating the
# secret here and restarting the stack — existing tokens will then be rejected
# (expected behavior on rotation).
JWT_SECRET=REPLACE_ME_WITH_OUTPUT_OF_openssl_rand_base64_48

# ---------------------------------------------------------------------------
# First-run super-admin bootstrap (user-service)
# ---------------------------------------------------------------------------
# Password for the initial SUPER_ADMIN (admin@innbucks.co.zw, override with
# BOOTSTRAP_ADMIN_EMAIL). REQUIRED to seed an admin under the prod profile —
# if unset in prod, NO admin is created (there is no hardcoded default any
# more). The seeded admin must change this password on first login. Generate:
#     openssl rand -base64 24
# Leave blank in non-prod (dev/test use a built-in fallback).
BOOTSTRAP_ADMIN_PASSWORD=

# ---------------------------------------------------------------------------
# Postgres credentials
# ---------------------------------------------------------------------------
# Used by docker-compose to bootstrap the postgres container and by every
# service via DB_USERNAME / DB_PASSWORD. POSTGRES_PASSWORD is required —
# docker-compose refuses to start without it.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme


# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
# Password for Redis (seat-locks, idempotency cache, gateway rate-limiter).
# REQUIRED in the deployed stack — Redis runs with --requirepass and every
# client authenticates with this value. Generate with: openssl rand -base64 32
REDIS_PASSWORD=

# ---------------------------------------------------------------------------
# Eureka registry auth
# ---------------------------------------------------------------------------
# HTTP Basic credential for the Eureka service registry (enforced under the
# prod profile). Every service embeds EUREKA_USERNAME:EUREKA_PASSWORD in its
# eureka defaultZone URL, so the password MUST be URL-safe (no @ : /). Generate:
#     openssl rand -hex 24
EUREKA_USERNAME=eureka
EUREKA_PASSWORD=

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
# Comma-separated list of allowed origins for the api-gateway and event-service.
# Defaults to http://localhost:3000 if unset. In production, set this to your
# real client origin(s), e.g.
#     CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
# Wildcard '*' is intentionally NOT supported because allowCredentials=true
# requires explicit origins per the CORS spec.
CORS_ALLOWED_ORIGINS=http://localhost:3000


# ---------------------------------------------------------------------------
# Gateway rate limiting
# ---------------------------------------------------------------------------
# Token bucket per resolved key (bearer token if present, else client IP).
# Replenish is the sustained req/sec rate; burst is the maximum bucket size.
# Defaults are conservative for local dev — tune up or down for production.
RATE_LIMIT_REPLENISH_PER_SECOND=50
RATE_LIMIT_BURST_CAPACITY=100


# ---------------------------------------------------------------------------
# S2S shared secrets
# ---------------------------------------------------------------------------
# ORADIAN_INTERNAL_TOKEN — X-Internal-Token sent by user-service and
# payment-service to the Oradian middleware. MUST equal the middleware's
# INTERNAL_API_TOKEN env var (in OradianMiddleware/.env on the same EC2),
# otherwise the middleware returns 401 invalid_internal_token on every S2S
# call. Generate with:
#     openssl rand -base64 32
ORADIAN_INTERNAL_TOKEN=REPLACE_ME_must_match_middleware_INTERNAL_API_TOKEN

# INTERNAL_API_TOKEN — separate shared secret used between ticketing's own
# services for /loyalty/internal/** webhook auth (user-service ->
# loyalty-service on tier-2 promotion, etc.). Can be a different value from
# ORADIAN_INTERNAL_TOKEN — purely internal to this stack.
INTERNAL_API_TOKEN=REPLACE_ME_separate_value_for_loyalty_webhooks

# ---------------------------------------------------------------------------
# loyalty-service signing secrets
# ---------------------------------------------------------------------------
# Sign loyalty vouchers / QR payloads. REQUIRED under the prod profile —
# loyalty-service's ProductionSecretsGuard refuses to boot while these still
# hold their change-me placeholder defaults. Generate each with:
#     openssl rand -base64 32
LOYALTY_VOUCHER_SECRET=
LOYALTY_QR_SECRET=

# ---------------------------------------------------------------------------
# WhatsApp notification gateway
# ---------------------------------------------------------------------------
# API key for the external WhatsApp gateway user-service uses to deliver OTPs
# and approval messages. REQUIRED by docker-compose (the user-service service
# declares it with ${WHATSAPP_API_KEY:?...}). Set the real key from your
# provider; the stack still boots without WhatsApp delivery if you supply a
# throwaway value, but OTP/registration messages won't send.
WHATSAPP_API_KEY=


# ---------------------------------------------------------------------------
# InnBucks Merchant API (2D-code ticket payments — POST /payments)
# ---------------------------------------------------------------------------
# Merchant API credentials used by payment-service to issue InnBucks PAYMENT
# codes (the customer approves the code in their own InnBucks app/USSD; there
# is no server-side wallet debit). All three credential vars are REQUIRED by
# docker-compose. The spec is pinned at docs/api/innbucks-merchant-api.md
# (distilled from docs/api/InnBucks_Merchant_Api_Doc_v1.0.9.pdf).
# NEVER commit real values; rotate immediately if they leak.
#
# BANK_API_URL                  — defaults to the staging base URL. (The
#                                 BANK_API_* names predate the merchant-API
#                                 rename — same platform, same credentials.)
# BANK_API_KEY                  — X-Api-Key header value.
# BANK_API_USERNAME / _PASSWORD — third-party client login
#                                 (POST /auth/third-party -> Bearer). The
#                                 client must be MERCHANT-typed and allowed
#                                 to generate PAYMENT codes — confirm with
#                                 the InnBucks team when they hand you creds.
BANK_API_URL=https://staging.innbucks.co.zw
BANK_API_KEY=
BANK_API_USERNAME=
BANK_API_PASSWORD=


# ---------------------------------------------------------------------------
# Local development workflow
# ---------------------------------------------------------------------------
# PostgreSQL is the runtime database; schema is owned by Flyway migrations
# under each service's src/main/resources/db/migration. Hibernate boots in
# `validate` mode and refuses to start if the JPA model and DB schema drift.
#
# Two ways to run locally:
#
# 1. Full stack via docker-compose:
#        docker compose up --build
#
#    Brings up Postgres + Redis + Kafka + the four services. The Postgres
#    container's init script creates one database per service.
#
# 2. Run a single service from your IDE / `mvn spring-boot:run`:
#        docker compose up -d postgres redis
#        ./mvnw -pl seat-service spring-boot:run
#
#    Make sure DB_PASSWORD (and DB_USERNAME if not `postgres`) is exported
#    in your shell — see scripts/dev-env.sh.
#
# Unit tests still use in-memory H2 (PostgreSQL compatibility mode) via
# src/test/resources/application-test.yaml and @ActiveProfiles("test").
