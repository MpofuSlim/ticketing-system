<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <!-- Standalone deployable on the InnBucks-core stack (Spring Boot 3.2.4 /
         Spring Cloud 2023.0.1) — deliberately NOT a module of the Boot-4
         ticketing reactor, so the innbucks.co.zw:core jar (and VeenguClient)
         can later be consumed natively without version-skew hacks. This is the
         connectivity spike: it only proves the adapter can reach the InnBucks
         Eureka cluster and discover veengu-integration. -->
    <parent>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-starter-parent</artifactId>
        <version>3.2.4</version>
        <relativePath/>
    </parent>

    <groupId>zw.co.innbucks</groupId>
    <artifactId>innbucks-core-gateway</artifactId>
    <version>0.1.0-SNAPSHOT</version>
    <name>innbucks-core-gateway</name>
    <description>Ticketing &lt;-&gt; InnBucks-core discovery adapter (connectivity spike)</description>

    <properties>
        <java.version>17</java.version>
        <spring-cloud.version>2023.0.1</spring-cloud.version>
    </properties>

    <dependencies>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-web</artifactId>
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-actuator</artifactId>
        </dependency>
        <!-- Eureka client: discovers veengu-integration in the InnBucks registry. -->
        <dependency>
            <groupId>org.springframework.cloud</groupId>
            <artifactId>spring-cloud-starter-netflix-eureka-client</artifactId>
        </dependency>
        <!-- InnBucks core: carries VeenguClient + Messenger/NotificationClient + payload DTOs.
             1.3.2 adds the multi-channel notification stack (NotificationClient v1,
             NotificationRequest, NotificationChannel, EmailPayload, WhatsAppPayload,
             NotificationStatusResponse) on top of the legacy MessengerClient/NotificationDto
             SMS path, which is what the new /notifications/{whatsapp,email} endpoints below
             ride on. Jetty is excluded so the adapter keeps the Tomcat it already gets from
             starter-web. -->
        <dependency>
            <groupId>innbucks.co.zw</groupId>
            <artifactId>core</artifactId>
            <version>1.3.2-RELEASE</version>
            <exclusions>
                <exclusion>
                    <groupId>org.springframework.boot</groupId>
                    <artifactId>spring-boot-starter-jetty</artifactId>
                </exclusion>
            </exclusions>
        </dependency>
    </dependencies>

    <dependencyManagement>
        <dependencies>
            <dependency>
                <groupId>org.springframework.cloud</groupId>
                <artifactId>spring-cloud-dependencies</artifactId>
                <version>${spring-cloud.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>
        </dependencies>
    </dependencyManagement>

    <build>
        <plugins>
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
            </plugin>
        </plugins>
    </build>
</project>
